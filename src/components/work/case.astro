---
import Overskrift from "../text/overskrift.astro";
import Underoverskrift from "../text/underoverskrift.astro";
import Brodtekst from "../text/brodtekst.astro";

let pil = ">";

const { video, href, titel, tekst, programs } = Astro.props;
---

<a href={href} class="group">
  <div class="grid lg:grid-cols-2 grid-cols-1 pb-10">
    <!-- video -->
    <div class="relative h-full bg-center bg-no-repeat bg-cover">
      <video
        src={video}
        muted
        loop
        playsinline
        preload="auto"
        class="w-full h-full object-cover"
        transition:name={`case-img-${titel}`}></video>
    </div>

    <!-- beskrivelse -->
    <div class="px-10 flex flex-col gap-6 h-full py-5">
      <div>
        <Overskrift>
          <h2>{titel}</h2>
        </Overskrift>
        <Underoverskrift><h3>{programs.join(", ")}</h3></Underoverskrift>
      </div>
      <Brodtekst><p>{tekst}</p></Brodtekst>
      <div class="mt-auto flex justify-end">
        <Overskrift>
          <h3
            class="transition-transform duration-200 group-hover:translate-x-2"
          >
            {pil}
          </h3>
        </Overskrift>
      </div>
    </div>
  </div>
</a>

<!-- afspiller video ved hover -->
<script is:inline>
  function initVideos() {
    document.querySelectorAll("a.group").forEach((link) => {
      const video = link.querySelector("video");
      if (!video) return;

      link.addEventListener("mouseenter", () => {
        const p = video.play();
        if (p) p.catch(() => {});
      });

      link.addEventListener("mouseleave", () => {
        video.pause();
        video.currentTime = 0;
      });
    });
  }

  initVideos();
  document.addEventListener("astro:page-load", initVideos);
</script>
