---
import Layout from "../layouts/Layout.astro";

import Overskrift from "../components/text/overskrift.astro";
import Titel from "../components/text/titel.astro";
import Underoverskrift from "../components/text/underoverskrift.astro";
import Brodtekst from "../components/text/brodtekst.astro";

import Nav from "../components/UI/nav.astro";
import Work from "../components/work/work.astro";
import Footer from "../components/UI/footer.astro";
---

<Layout>
  <div class="grid gap-25">
    <Nav />

    <div class="mx-auto max-w-9xl grid gap-5">
      <div class="2xl:px-0 px-10">
        <Titel>Work</Titel>
      </div>
      
      <Work />
    </div>

    <Footer />
  </div>
</Layout>
